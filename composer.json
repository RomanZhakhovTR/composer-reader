{
    "name": "ability/composer-reader",
    "description": "A simple composer.json file reader",
    "type": "library",
    "require": {
        "php": "^8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "keywords": [
        "composer",
        "reader"
    ],
    "autoload": {
        "psr-4": {
            "Ability\\ComposerReader\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ability\\ComposerReader\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "authors": [
        {
            "name": "Roman Zhakhov",
            "email": "roman.zhakhov@thomsonreuters.com"
        }
    ],
    "license": "MIT"
}